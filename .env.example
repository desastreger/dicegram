# ─── Required ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-me-with-a-long-random-string

# ─── Session / cookies ─────────────────────────────────────────────────────
# true = cookie only sent over HTTPS. Leave true for any real deployment.
SESSION_COOKIE_SECURE=true

# ─── Database ──────────────────────────────────────────────────────────────
# Default SQLite path lives on the dicegram_data volume. Override with a
# Postgres URL like: postgresql+psycopg://user:pass@host:5432/dicegram
DATABASE_URL=sqlite:////data/dicegram.db

# ─── Runtime ───────────────────────────────────────────────────────────────
# Number of uvicorn worker processes. 2 is fine for a 1–2 vCPU VPS.
WEB_CONCURRENCY=2

# ─── Caddy (only needed when using the `caddy` compose profile) ───────────
# The domain Caddy will serve and request a Let's Encrypt cert for.
DOMAIN=dicegram.example.com
# Email used for ACME/Let's Encrypt registration and expiry notices.
ACME_EMAIL=you@example.com
