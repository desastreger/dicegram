# ─── Required ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-me-with-a-long-random-string

# ─── Session / cookies ─────────────────────────────────────────────────────
# true = cookie only sent over HTTPS. Leave true for any real deployment.
SESSION_COOKIE_SECURE=true

# ─── Database ──────────────────────────────────────────────────────────────
# Default SQLite path lives on the dicegram_data volume. Override with a
# Postgres URL like: postgresql+psycopg://user:pass@host:5432/dicegram
DATABASE_URL=sqlite:////data/dicegram.db

# ─── Runtime ───────────────────────────────────────────────────────────────
# Number of uvicorn worker processes. 2 is fine for a 1–2 vCPU VPS.
WEB_CONCURRENCY=2

# ─── Email / outbound ──────────────────────────────────────────────────────
# Public base URL used to build verification / password-reset links in
# outbound emails. Must be reachable from a user's browser.
APP_BASE_URL=https://dicegram.example.com

# Leave SMTP_HOST empty to log emails to stdout instead of sending them —
# useful while you're setting things up. Once you have a transactional
# sender (SES, Postmark, Mailgun, SendGrid, Resend, or a self-hosted
# Postfix), fill these in.
SMTP_HOST=
SMTP_PORT=587
# STARTTLS on 587 = true. SMTPS on 465 = false.
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@dicegram.example.com
SMTP_FROM_NAME=Dicegram

# ─── Caddy (only needed when using the `caddy` compose profile) ───────────
# The domain Caddy will serve and request a Let's Encrypt cert for.
DOMAIN=dicegram.example.com
# Email used for ACME/Let's Encrypt registration and expiry notices.
ACME_EMAIL=you@example.com
