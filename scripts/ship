#!/usr/bin/env bash
# One-call stage + commit + push. Replaces the heredoc dance.
#
# Usage:
#   scripts/ship "title"
#   scripts/ship "title" "body line 1" "body line 2"
#   scripts/ship -a "title" "body"            # stage untracked too (git add -A)
#   scripts/ship --amend ["new title"]        # amend last commit
#   scripts/ship --no-push "title"            # commit only, don't push
#   echo "body via stdin" | scripts/ship "title" -
#
# Default stage is `git add -u` (only tracked changes) — safer than -A
# which sweeps up untracked secrets or binaries.
#
# Appends the standard Co-Authored-By trailer automatically.

set -euo pipefail

add_mode="u"          # -u tracked, -A everything
push=1
amend=0
read_stdin=0
title=""
body_lines=()

while (($#)); do
  case "$1" in
    -a|--all) add_mode="A"; shift ;;
    --no-push) push=0; shift ;;
    --amend) amend=1; shift ;;
    -h|--help)
      sed -n '2,15p' "$0"
      exit 0
      ;;
    -) read_stdin=1; shift ;;
    *)
      if [[ -z "$title" ]]; then
        title="$1"
      else
        body_lines+=("$1")
      fi
      shift
      ;;
  esac
done

if [[ $read_stdin -eq 1 ]]; then
  # Append stdin as its own paragraph of the body.
  body_lines+=("$(cat)")
fi

# Warn about untracked files before staging — the default `-u` path only
# stages tracked changes, so a newly-created file would silently be left
# out of the commit (and break a fresh clone / deploy).
untracked=$(git ls-files --others --exclude-standard)
if [[ -n "$untracked" && "$add_mode" != "A" ]]; then
  echo "ship: warning — untracked files NOT being committed:" >&2
  while IFS= read -r f; do
    [[ -n "$f" ]] && echo "  ? $f" >&2
  done <<<"$untracked"
  echo "       re-run with -a to include them, or 'git add <file>' first." >&2
fi

# Stage tracked changes.
git add "-${add_mode}"

# Bail early if there's nothing to commit (unless we're amending — amend
# is allowed even with an empty index to, e.g., just fix the message).
if [[ $amend -eq 0 ]] && git diff --cached --quiet; then
  echo "ship: no staged changes — nothing to commit." >&2
  exit 1
fi

trailer="Co-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>"

# Build the full message. Title on its own line; blank line; then each
# body arg becomes a paragraph separated by blank lines; final blank line;
# then the trailer.
{
  if [[ -n "$title" ]]; then
    printf '%s\n' "$title"
    if ((${#body_lines[@]})); then
      printf '\n'
      for i in "${!body_lines[@]}"; do
        [[ $i -gt 0 ]] && printf '\n'
        printf '%s\n' "${body_lines[$i]}"
      done
    fi
    printf '\n%s\n' "$trailer"
  fi
} >/tmp/ship-msg.$$

if [[ $amend -eq 1 && -z "$title" ]]; then
  # Amend with existing message, just re-stage.
  git commit --amend --no-edit
elif [[ $amend -eq 1 ]]; then
  git commit --amend -F /tmp/ship-msg.$$
else
  git commit -F /tmp/ship-msg.$$
fi
rm -f /tmp/ship-msg.$$

if [[ $push -eq 1 ]]; then
  branch=$(git rev-parse --abbrev-ref HEAD)
  if [[ "$branch" == "HEAD" ]]; then
    echo "ship: detached HEAD — skipping push." >&2
    exit 0
  fi
  if [[ $amend -eq 1 ]]; then
    # Amending a pushed commit rewrites history — force-with-lease is the
    # safe form (fails if someone else pushed in the meantime).
    git push --force-with-lease origin "$branch"
  else
    git push origin "$branch"
  fi
fi
